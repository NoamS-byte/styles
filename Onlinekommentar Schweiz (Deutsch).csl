<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" class="note" version="1.0" default-locale="de">
  <info>
   <title>Onlinekommentar Schweiz (Deutsch)</title>
   <id>http://www.zotero.org/styles/onlinekommentar-schweiz</id>
   <link href="http://www.zotero.org/styles/onlinekommentar-schweiz" rel="self"/>
   <link href="http://www.zotero.org/styles/juristische-zitierweise-schweizer" rel="template"/>
   <author>
    <name>Noam Schank</name>
    <email>schank.noam@gmail.com</email>
   </author>
   
  <category citation-format="note"/>
  <category field="law"/>
  <summary>This style is based on the citation guidelines of Onlinekommentar (German edition).</summary>
  <updated>2026-07-06T08:00:00+00:00</updated>
  <rights license="https://creativecommons.org/licenses/by-sa/4.0/">This work is licensed under a Attribution-ShareAlike 4.0 International License.</rights>
    <!-- 
	* Publizierter Urteile (sämtlicher Schweizer Gerichte) wird das Aktenzeichen vollständig 	im Titel-Feld zitiert. Soll der Name, unter dem das Urteil bekannt wurde – etwa «PKK» 		für BGE 125 II 417 –, hinten angefügt werden, kann dafür das Feld «Kurztitel» verwendet 	werden. Das sollte dann so aussehen: BGE 125 II 417, E. 4a S. 240, PKK. Kursivdruck und 	Komma sind automatisiert.
	* Unpublizierte Urteile (sämtlicher Schweizer Gerichte): Titel leerlassen, Aktenzeichen 	und Beschlussdatum einfügen; Fundstelle: Für den Fall, dass eine Zeitschrift, in 		der das Urteil abgedruckt wurde, angegeben werden soll. Einfach die gesamte 			Fundstelle manuell in das Feld eintragen – z. B. ZBl 92 (1991)). (Erste Seite: Dieses 		Feld nur benutzen, wenn eine Zeitschrift angegeben wird. Dann können hier die 			entsprechenden Seiten, auf denen das Urteil abgedruckt wurde – mithin der Umfang, nicht 	die genaue Fundstelle –, angegeben werden (ohne Präfix «S.»))
	* Für Kommentare »Enyzklopädieartikel« verwenden; für besondere Zitierweise (BSK-Epiney, 	Art. 36 BV) in Fussnoten Kurztitel verwenden.
	* Für Rechtsgutachten »Bericht«
	* Materialien: Botschaften/Berichte »Dokument« verwenden, Kurztitel für Zitierweise in 		den Fussnoten, Verlag: Eintrag im BBl; «Anhörung» für Voten in der BVers o. dgl.
    -->
  </info>
  <locale xml:lang="de">    
   <terms>
    <term name="volume">Band</term>
    <term name="accessed">besucht am</term>
    <term name="editor">Hrsg.</term>
    <term name="et-al">et al.</term>
    <term name="page">S.</term>
    <term name="note">N.</term>
    <term name="paragraph">§</term>
    <term name="section">E.</term>
   </terms>
  </locale>
  <macro name="author">
   <names variable="author">
    <name delimiter="/" name-as-sort-order="all" sort-separator=" " form="long" font-style="normal"/>
     <label form="short" prefix=" (" suffix=")"/>
    <substitute>
     <names variable="editor"/>
    </substitute>
   </names>
  </macro>
  <macro name="editor-author">
   <names variable="editor">
    <name delimiter="/" name-as-sort-order="all" sort-separator=" " form="long" font-style="normal"/>
     <label form="short" prefix=" (" suffix=")"/>
    <substitute>
     <names variable="author"/>
    </substitute>
   </names>
  </macro>
  <macro name="author-note">
   <names variable="author">
    <name form="short" delimiter="/" et-al-min="5" et-al-use-first="1" name-as-sort-order="all" font-style="normal"/>
   </names>
  </macro>
  <macro name="author-editor-note">
   <names variable="author">
    <name form="short" delimiter="/" et-al-min="5" et-al-use-first="1" sort-separator="" font-style="normal"/>
    <substitute>
     <names variable="editor"/>
    </substitute>
   </names>
  </macro>
  <macro name="issued-date">
   <date variable="issued" prefix="vom ">
    <date-part name="day" suffix="."/>
    <date-part name="month" form="numeric" suffix="."/>
    <date-part name="year"/>
   </date>
  </macro>
  <macro name="issued-date-document">
   <date variable="issued">
    <date-part name="year"/>
   </date>
  </macro>
  <macro name="issued-date-hearing">
   <date variable="issued">
    <date-part name="year"/>
   </date>
  </macro>
  <macro name="accessed-date">
   <date variable="accessed">
    <date-part name="day" suffix=". "/>
    <date-part name="month" form="long" suffix=" "/>
    <date-part name="year"/>
   </date>
  </macro>
  <macro name="locator">
   <choose>
    <if locator="page">
     <group delimiter=" ">
      <text value="S."/>
      <text variable="locator"/>
     </group>
    </if>
    <else-if locator="note">
     <group delimiter=" ">
      <text value="N."/>
      <text variable="locator"/>
     </group>
    </else-if>
    <else-if locator="paragraph">
     <group delimiter=" ">
       <text value="§"/>
       <text variable="locator"/>
     </group>
    </else-if>
    <else-if locator="section">
     <group delimiter=" ">
       <text value="E."/>
       <text variable="locator"/>
     </group>
    </else-if>
    <else>
     <group delimiter=" ">
      <label variable="locator" form="short" suffix=" "/>
      <text variable="locator"/>
     </group>
    </else>
   </choose>
  </macro>
  <citation>
    <layout delimiter="; " suffix=".">
      <choose>
       <if type="article-journal">
        <group delimiter=", ">
         <text macro="author-note"/>
         <text variable="title-short"/>
         <text macro="locator"/>
        </group>
       </if>
       <else-if type="book">
        <group delimiter=", ">
         <text macro="author-editor-note"/>
         <text variable="title-short"/>
         <text macro="locator"/>
        </group>
        </else-if>
        <else-if type="thesis">
         <group delimiter=", ">
          <text macro="author-editor-note"/>
          <text variable="title-short"/>
          <text macro="locator"/>
         </group>
        </else-if>
        <else-if type="chapter">
         <group delimiter=", ">
          <text macro="author-note"/>
          <text variable="title-short"/>
          <text macro="locator"/>
         </group>
        </else-if>
        <else-if type="entry-encyclopedia">
         <text variable="title-short"/>
         <text macro="locator"/>
        </else-if>
        <else-if type="legal_case" match="any">
         <group delimiter=", ">
          <text variable="title"/>
          <group delimiter=" ">
           <text variable="authority"/>
           <text macro="issued-date"/>
          </group>
          <text variable="note"/>
          <text variable="title-short" font-style="italic" prefix="&#8211; "/>
          <text macro="locator"/>
         </group>
        </else-if>
        <else-if type="document">
         <group delimiter=", ">
          <text variable="title-short"/>
          <text macro="issued-date-document"/>
          <text macro="locator"/>
         </group>
        </else-if>
        <else-if type="hearing">
         <group delimiter=" ">
          <text variable="title" suffix=", "/>
          <text variable="publisher"/>
          <text macro="issued-date-hearing"/>
          <text variable="authority"/>
          <text macro="locator"/>
         </group>
        </else-if>
        <else-if type="report">
         <group delimiter=", ">
          <text macro="author-note"/>
          <text variable="title-short"/>
          <text macro="locator"/>
         </group>
        </else-if>
        <else>
         <group delimiter=", ">
          <text macro="author-note"/>
          <text variable="title-short"/>
          <text macro="locator"/>
         </group>
        </else>
      </choose>
    </layout>
  </citation>
  <bibliography subsequent-author-substitute="ders." line-spacing="1" hanging-indent="true">
    <sort>
      <key macro="author"/>
      <key variable="issued"/>
    </sort>
    <layout suffix=".">
      <choose>
       <if type="article-journal">
         <group delimiter=", ">
          <text macro="author"/>
          <text variable="title"/>
          <group delimiter=" ">
           <text variable="container-title" form="short" suffix=" "/>
            <choose>
             <if match="any" variable="volume">
              <group delimiter=" ">
               <text variable="volume"/>
              </group>
              <group>
               <date date-parts="year" form="text" variable="issued" prefix="(" suffix="), "/>
               <text variable="page" prefix=" S. "/>
              </group>
             </if>
             <else-if match="any" variable="issue">
              <group delimiter="">
               <text variable="issue"/>
               <date date-parts="year" form="text" variable="issued" prefix="/"/>
               <text variable="page" prefix=", "/>
              </group>
             </else-if>
             <else>
              <group delimiter="">
               <date date-parts="year" form="text" variable="issued"/>
               <text variable="page" prefix=", "/>
              </group>
             </else>
            </choose>
           </group>
          </group>
         <choose>
          <if match="any" variable="DOI">
           <text variable="DOI" prefix=", DOI: "/>
          </if>
          <else>
           <group delimiter=" " prefix=", ">
            <text variable="URL" prefix="&lt;" suffix="&gt; "/>
            <group delimiter=" " prefix="(" suffix=")">
             <text term="accessed"/>
             <text macro="accessed-date"/>
            </group>
           </group>
          </else>
          </choose>
          <choose>
            <if match="any" variable="title-short">
              <group delimiter=", " prefix=" (zit.: " suffix=")">
                <text macro="author-editor-note"/>
                <text variable="title" form="short"/>
              </group>
            </if>
           </choose>
        </if>
        <else-if type="book">
          <group delimiter=", ">
            <text macro="author"/>
            <text variable="title"/>
            <choose>
             <if match="any" variable="volume">
              <group delimiter=" ">
               <text term="volume"/>
               <text variable="volume"/>
              </group>
             </if>
            </choose>
            <text variable="edition" suffix=" Aufl."/>
            <group delimiter=" ">
              <text variable="publisher-place"/>
              <date date-parts="year" form="text" variable="issued"/>
            </group>
          </group>
          <choose>
            <if match="any" variable="title-short">
              <group delimiter=", " prefix=" (zit.: " suffix=")">
                <text macro="author-editor-note"/>
                <text variable="title" form="short"/>
              </group>
            </if>
          </choose>
        </else-if>
        <else-if type="chapter">
         <group delimiter=", ">
          <text macro="author"/>
          <text variable="title"/>
          <group delimiter=": ">
           <text term="in"/>
           <group delimiter=", ">
            <names variable="editor">
             <name delimiter="/" name-as-sort-order="all" sort-separator=", " form="long"/>
              <label form="short" prefix=" (" suffix=")"/>
             </names>
             <text variable="container-title"/>
            </group>
           </group>
           <choose>
            <if match="any" variable="volume">
             <group delimiter=" ">
              <text term="volume"/>
              <text variable="volume"/>
             </group>
            </if>
           </choose>
           <text variable="edition" suffix=" Aufl."/>
           <group delimiter=" ">
            <text variable="publisher-place"/>
             <date date-parts="year" form="text" variable="issued"/>
           </group>
          <text variable="page" prefix="S. "/>
         </group>
         <choose>
          <if match="any" variable="title-short">
           <group delimiter=", " prefix=" (zit.: " suffix=")">
            <text macro="author-editor-note"/>
            <text variable="title" form="short"/>
           </group>
          </if>
         </choose>
        </else-if>
        <else-if type="thesis">
         <group delimiter=", ">
          <text macro="author"/>
          <text variable="title"/>
          <text variable="genre"/>
          <group delimiter=" ">
           <text variable="publisher-place"/>
           <date date-parts="year" form="text" variable="issued"/>
           <choose>
            <if match="any" variable="title-short">
             <group delimiter=", " prefix=" (zit.: " suffix=")">
              <text macro="author-editor-note"/>
              <text variable="title" form="short"/>
             </group>
            </if>
           </choose>
          </group>
         </group>
        </else-if>
        <else-if type="entry-encyclopedia">
          <group delimiter=", ">
            <text macro="author"/>
            <choose>
              <if variable="title" match="all">
                <text variable="title" prefix="Kommentierung zu "/>
                <text macro="editor-author" prefix="in: "/>
              </if>
            </choose>
            <text variable="container-title"/>
            <choose>
             <if match="any" variable="volume">
              <group delimiter=" ">
               <text term="volume"/>
               <text variable="volume"/>
              </group>
             </if>
            </choose>
            <text variable="edition" suffix=" Aufl."/>
            <group delimiter="">
              <text variable="publisher-place" suffix=" "/>
              <date variable="issued" suffix="">
                <date-part name="year" form="long"/>
              </date>
            </group>
          </group>
        </else-if>
        <else-if type="legal_case" match="any">
          <!-- no entry -->
        </else-if>
        <else-if type="document">
         <group delimiter=", ">
          <group delimiter=" ">
           <text variable="title"/>
           <text macro="issued-date"/>
          </group>
          <text variable="publisher"/>
         <group delimiter=" ">
           <text value="abrufbar unter"/>
           <text variable="URL" prefix="&lt;" suffix="&gt;"/>
          </group>
          <group delimiter=" ">
           <text term="accessed"/>
           <text macro="accessed-date"/>
          </group>
         </group>
        </else-if>      
        <else-if type="hearing">
         <group delimiter=" ">
          <text variable="title" suffix=", "/>
          <text variable="publisher"/>
          <text macro="issued-date-hearing"/>
          <text variable="authority"/>
          <text variable="page"/>
         </group>
        </else-if>
        <else-if type="report">
         <group delimiter=", ">
          <text macro="author"/>
          <text variable="title"/>
          <date variable="issued" suffix="">
           <date-part name="year" form="long"/>
          </date>
          <text variable="page"/>
         </group>
        </else-if>
        <else>
         <group delimiter=", ">
          <text macro="author"/>
          <text variable="title"/>
          <group delimiter=" ">
           <text variable="URL" prefix="&lt;" suffix="&gt; "/>
           <group delimiter=" " prefix="(" suffix=")">
            <text term="accessed"/>
            <text macro="accessed-date"/>
           </group>
           <text variable="page"/>
           <text variable="title-short" prefix=" (zit.: " suffix=")"/>
          </group>
         </group>
        </else>
      </choose>
    </layout>
  </bibliography>
</style>
